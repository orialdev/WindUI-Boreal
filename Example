        Size = 14
    }
})

local function notify(title, content, icon, duration)
    WindUI:Notify({
        Title = title,
        Content = content,
        Icon = icon,
        Duration = duration or 4
    })
end

Window:OnOpen(function()
    notify("Window", "Opened successfully.", "check", 2)
end)

Window:OnClose(function()
    notify("Window", "Closed.", "panel-left-close", 2)
end)

Window:OnDestroy(function()
    print("Window destroyed")
end)

Window:BindShortcut("RightShift", function()
    Window:Toggle()
end, {
    Description = "Toggle window",
    EnabledWhenClosed = true
})

Window:BindShortcut("F5", function()
    notify("Shortcut", "Pressed F5.", "keyboard", 2)
end)

